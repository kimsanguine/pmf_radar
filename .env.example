# =============================================================================
# pmf_radar — .env.example
#
# 로컬 개발용. Cloudflare Workers 의 secret 은 `wrangler secret put <KEY>` 로 등록.
# 절대 실제 값을 이 파일에 넣지 말 것 (.env 는 .gitignore 로 제외됨).
# =============================================================================

# --- LLM (server.py /api/classify 가 사용) ---
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o-mini

# --- Supabase (P2 운영 DB) ---
# https://<project>.supabase.co 형식
SUPABASE_URL=https://your-project.supabase.co
# service_role key — Workers 도 동일 값 사용 (anon DENY 정책이므로 service_role 필수)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# --- Telegram 알림 (P2 운영자 통지) ---
TELEGRAM_BOT_TOKEN=1234567890:AAA...
TELEGRAM_OPERATOR_CHAT_ID=123456789

# --- 4채널 인입 인증 토큰 ---
# Channel Talk webhook ?token=<value> URL query
CHANNEL_TALK_WEBHOOK_TOKEN=changeme-channel-talk
# (선택) Kakao Consultalk 파트너 API key
KAKAO_WEBHOOK_TOKEN=changeme-kakao

# --- AWS SES → SNS 인입 (email Worker) ---
SNS_TOPIC_ARN=arn:aws:sns:ap-northeast-1:000000000000:pmf-radar-email-inbound

# --- 내부 API ---
# scripts/* 가 운영자 dashboard 와 통신할 때
INBOX_READ_TOKEN=changeme-read-token
INTERNAL_API_KEY=changeme-internal-api

# --- 운영 설정 (server.py 로컬 실행) ---
PORT=8892
CS_INBOX_ROOT=./data
DASHBOARD_BASE_URL=http://127.0.0.1:8892
PUBLIC_WEBHOOK_BASE_URL=https://inbox.habix.ai

# --- Feature flags (boolean — "true"/"false") ---
# Kakao Consultalk 파트너 권한 확보 여부
KAKAO_CONSULTALK_PARTNER_READY=false
# Kakao 공식 payload 형식 확정 여부
KAKAO_OFFICIAL_PAYLOAD_CONFIRMED=false

# --- Channel Talk HMAC (현재 미사용 — 호환성 유지) ---
CHANNEL_TALK_WEBHOOK_SECRET=
