{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./.tsbuild",
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["./**/*.ts"],
  "exclude": [".tsbuild", "node_modules"]
}
